# ─────────────────────────────────────────────────────────────
# OmniBrain — Environment Variables
# Copy this file to .env.local and fill in the values
# NEVER commit .env.local to git
# ─────────────────────────────────────────────────────────────

# Supabase (from: supabase.com → your project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role (from same page — keep this SECRET, never NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Anthropic API Key (from: console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
